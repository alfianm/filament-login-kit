{
    "name": "alfianm/filament-login-kit",
    "description": "Beautiful, customizable login layouts for Filament v3, v4, and v5",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "filament",
        "filament-v3",
        "filament-v4", 
        "filament-v5",
        "login",
        "auth",
        "split-login",
        "overlay-login",
        "filament-plugin"
    ],
    "authors": [
        {
            "name": "Alfian Maulana",
            "email": "alfian@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "filament/filament": "^3.0|^4.0|^5.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^7.0|^8.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "AlfianM\\FilamentLoginKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AlfianM\\FilamentLoginKit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AlfianM\\FilamentLoginKit\\LoginKitServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
